pipeline {
    agent any
    
    stages {
        stage('Git Cloning') {
            steps {
                git branch: 'main', url: 'https://github.com/Ankush-9/jenkins-docker-k8s-cicd.git'
            }
        }
        stage('K8S-Deployment') {
            steps {
                script{
                    sh 'kubectl apply -f k8s-deployment.yml'
                }
            }
        }
    }
    post{
        failure{
            emailext (
            attachLog: true,
            body: 'The Build was failed due to some errors',
            replyTo: 'waliaankush0420@gmail.com',
            subject: 'Failure',
            to: 'elfforest25@gmail.com'
        )
        }
        success{
            emailext (
            attachLog: true,
            body: 'The Build was Successful',
            replyTo: 'waliaankush0420@gmail.com',
            subject: 'Success',
            to: 'elfforest25@gmail.com'
        )
        }
    }
}
